VIGILIA_ENV=development
VIGILIA_MODE=dry-run
VIGILIA_RUNTIME_DIR=runtime
VIGILIA_LOG_LEVEL=INFO
VIGILIA_MODEL_BACKEND=stub
VIGILIA_TRANSCRIPTION_BACKEND=sidecar
VIGILIA_WHISPER_MODEL=tiny
VIGILIA_OLLAMA_MODEL=llama3.2:3b
VIGILIA_OLLAMA_TIMEOUT_SECONDS=8

# First Mac mini M4 + GDS3725 SIP test profile.
VIGILIA_SIP_LOCAL_USER=vigilia
VIGILIA_SIP_LOCAL_DOMAIN=192.168.100.50
VIGILIA_SIP_LOCAL_PORT=5060
VIGILIA_SIP_TRANSPORT=udp

VIGILIA_SIP_DEVICE_LABEL=gds3725
VIGILIA_SIP_DEVICE_USER=door
VIGILIA_SIP_DEVICE_DOMAIN=192.168.100.60
VIGILIA_SIP_DEVICE_PORT=5060

VIGILIA_BARESIP_BINARY=baresip
VIGILIA_BARESIP_CONFIG_PATH=runtime/baresip/config
VIGILIA_BARESIP_ACCOUNTS_PATH=runtime/baresip/accounts
VIGILIA_BARESIP_AUDIO_PATH=runtime/baresip/audio
VIGILIA_BARESIP_WORKDIR=runtime/baresip
VIGILIA_HELLO_SIP_DOMAIN=192.168.100.50
VIGILIA_HELLO_VOICE="Rocko (Español (México))"
VIGILIA_HELLO_TEXT="Hola, soy MatIA. Te escucho."

# Real opening is opt-in and must use local, untracked secrets.
VIGILIA_GATE_BACKEND=dry-run
VIGILIA_GDS_BASE_URL=http://192.168.100.60
VIGILIA_GDS_USERNAME=
VIGILIA_GDS_PASSWORD=
VIGILIA_GDS_REMOTE_PIN=
VIGILIA_GDS_OPEN_TYPE=1

# Local lab service loop.
VIGILIA_SERVICE_RESTART_SECONDS=2
